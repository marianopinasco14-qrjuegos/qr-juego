# ─────────────────────────────────────────────
# REPLIT: Estas variables van en "Secrets" (el candado en el panel izquierdo)
# NO crear un archivo .env en Replit. Usar Secrets directamente.
# ─────────────────────────────────────────────

# PostgreSQL - Replit la genera automáticamente cuando agregás la DB
# Va a tener un formato similar a este:
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Generá un string random de 32+ caracteres para esto
# Podés usar: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET="reemplaza-con-un-string-random-de-32-caracteres"

# La URL pública de tu Repl (la encontrás arriba cuando corre el proyecto)
# Formato: https://tu-nombre-del-repl.tu-usuario.repl.co
NEXTAUTH_URL="https://tu-repl-url.repl.co"

# API Key de Resend para enviar emails (gratis en resend.com)
# Por ahora podés dejar este valor y los emails simplemente no se envían
RESEND_API_KEY="re_demo_sin_envio_real"

# Secret para firmar cookies anti-fraude (32+ caracteres random)
COOKIE_SECRET="otro-string-random-de-32-caracteres-minimo"

# URL pública del proyecto (igual que NEXTAUTH_URL)
NEXT_PUBLIC_APP_URL="https://tu-repl-url.repl.co"

# Tu email de administrador
SUPERADMIN_EMAIL="admin@qrjuego.com"

# Tu contraseña de administrador
SUPERADMIN_PASSWORD="Admin123!"
