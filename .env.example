# ─────────────────────────────────────────────
# REPLIT: Estas variables van en "Secrets" (el candado en el panel izquierdo)
# NO crear un archivo .env en Replit. Usar Secrets directamente.
# ─────────────────────────────────────────────

# PostgreSQL - Replit la genera automáticamente cuando agregás la DB
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# JWT / Auth
NEXTAUTH_SECRET="reemplaza-con-un-string-random-de-32-caracteres"
NEXTAUTH_URL="https://tu-repl-url.repl.co"
COOKIE_SECRET="otro-string-random-de-32-caracteres-minimo"
NEXT_PUBLIC_APP_URL="https://tu-repl-url.repl.co"

# Admin
SUPERADMIN_EMAIL="admin@qrjuego.com"
SUPERADMIN_PASSWORD="Admin123!"

# Email (Resend) - gratis en resend.com
RESEND_API_KEY="re_demo_sin_envio_real"

# Cloudinary (imágenes) - gratis en cloudinary.com
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="tu-api-key"
CLOUDINARY_API_SECRET="tu-api-secret"

# ─── Pagos ────────────────────────────────────────────────────────────────────

# Paddle (mercados internacionales) - paddle.com
# Obtené las credenciales en: paddle.com/dashboard > Developer Tools > Authentication
PADDLE_API_KEY="pdl_live_xxx"
PADDLE_WEBHOOK_SECRET="pdl_ntfset_xxx"  # En Paddle: Notifications > Webhook > Secret

# Dlocal (LATAM: AR, BR, MX, CO, CL, PE, UY)
# Obtené las credenciales en tu panel Dlocal
DLOCAL_API_KEY="tu-dlocal-api-key"
DLOCAL_SECRET="tu-dlocal-secret"
DLOCAL_URL="https://sandbox.dlocal.com"  # Cambiar a https://api.dlocal.com en producción
